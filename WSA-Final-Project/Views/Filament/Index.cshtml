@using System.Linq
@model IEnumerable<WSA_Final_Project.Models.Filament>
@{
    ViewData["Title"] = "Filaments";
}

<h1>@ViewData["Title"]</h1>

<p>
    This is a non-exhaustive list of list of some 3D printer filaments. 
    I don't have personal experience with resin printers, so I will not inlcude information on the different types of resin.
	This list is focused on common FDM printer filaments, with a focus on the materials I am familiar with, 
    but there are many other types of filaments available with different properties and characteristics that may be better suited for specific applications.
</p>

<p>
    This list is also accessible in JSON format <a asp-controller="Filament" asp-action="GetAllFilaments">here</a>.
</p>

@if (Model != null && Model.Any())
{
    <table class="table table-striped table-bordered">
        <thead class="table-light">
            <tr>
                <th>Material</th>
                <th>Material Full Name</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var f in Model)
            {
                <tr>
                    <td>@f.Material</td>
                    <td>@f.MaterialFull</td>
                    <td>@f.Description</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">No filaments available.</div>
}
